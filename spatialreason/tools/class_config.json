  "_detection_filtering": {
    "_description": "Detection tool filtering parameters for improved performance",
    "global_settings": {
      "global_min_confidence": 0.35,
      "default_min_area_ratio": 0.003,
      "default_top_k": 3,
      "use_percentile_thresholds": false,
      "percentile_threshold": 90
    },
    "per_class_confidence": {
      "forest": 0.40,
      "barren": 0.45,
      "building": 0.50,
      "road": 0.35,
      "water": 0.40,
      "agriculture": 0.35,
      "vegetation": 0.40,
      "trees": 0.40,
      "grass": 0.35,
      "aircraft": 0.55,
      "cars": 0.50,
      "ship": 0.50,
      "default": 0.40
    },
    "per_class_min_area_ratio": {
      "forest": 0.005,
      "barren": 0.004,
      "building": 0.002,
      "road": 0.003,
      "water": 0.004,
      "agriculture": 0.005,
      "vegetation": 0.004,
      "trees": 0.004,
      "grass": 0.003,
      "aircraft": 0.001,
      "cars": 0.0005,
      "ship": 0.002,
      "default": 0.003
    },
    "nms_settings": {
      "enable_soft_nms": true,
      "soft_nms_sigma": 0.5,
      "intra_class_iou_threshold": 0.45,
      "cross_class_iou_threshold": 0.3,
      "confused_class_pairs": [
        ["forest", "barren"],
        ["forest", "vegetation"],
        ["trees", "vegetation"],
        ["grass", "vegetation"],
        ["building", "road"]
      ]
    },
    "top_k_selection": {
      "per_class_top_k": {
        "forest": 3,
        "barren": 3,
        "building": 5,
        "road": 4,
        "water": 3,
        "agriculture": 3,
        "vegetation": 3,
        "trees": 3,
        "grass": 2,
        "aircraft": 10,
        "cars": 15,
        "ship": 8,
        "default": 3
      },
      "selection_criteria": "area_desc"
    }
  },

  "_spatial_analysis": {
    "_description": "Spatial analysis pipeline settings for simplified single-instance processing",
    "geometry_selection": {
      "use_top_1_instances": true,
      "selection_criteria": "area_desc",
      "fallback_to_highest_confidence": true,
      "require_minimum_area_pixels": 100
    },
    "logging": {
      "log_selection_decisions": true,
      "log_discarded_instances": true,
      "log_filtering_statistics": true,
      "verbosity_level": "detailed"
    },
    "class_prioritization": {
      "enable_priority_ranking": false,
      "priority_order": ["building", "water", "forest", "road", "agriculture", "barren"],
      "use_priority_for_ties": true
    },
    "performance_tracking": {
      "track_processing_time": true,
      "track_geometry_count_reduction": true,
      "track_analysis_quality_metrics": true,
      "save_before_after_comparisons": false
    },
    "validation": {
      "require_valid_geometries": true,
      "minimum_geometry_area_ratio": 0.001,
      "validate_spatial_relationships": true
    }
  }
}
